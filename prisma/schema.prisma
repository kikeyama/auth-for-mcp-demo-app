generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  auth0Id      String        @unique @map("auth0_id")
  email        String        @unique
  name         String?
  picture      String?
  cashBalance  Decimal       @default(10000000) @map("cash_balance") @db.Decimal(18, 2)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  holdings     Holding[]
  transactions Transaction[]

  @@map("users")
}

model Asset {
  id             String        @id @default(cuid())
  symbol         String        @unique
  name           String
  type           AssetType
  currency       String        @default("JPY")
  currentPrice   Decimal       @map("current_price") @db.Decimal(18, 6)
  priceUpdatedAt DateTime      @default(now()) @map("price_updated_at")
  holdings       Holding[]
  transactions   Transaction[]
  prices         AssetPrice[]

  @@map("assets")
}

model AssetPrice {
  id         String   @id @default(cuid())
  assetId    String   @map("asset_id")
  price      Decimal  @db.Decimal(18, 6)
  recordedAt DateTime @default(now()) @map("recorded_at")
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, recordedAt(sort: Desc)])
  @@map("asset_prices")
}

model Holding {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  assetId   String   @map("asset_id")
  quantity  Decimal  @db.Decimal(18, 6)
  avgCost   Decimal  @map("avg_cost") @db.Decimal(18, 6)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset     Asset    @relation(fields: [assetId], references: [id])

  @@unique([userId, assetId])
  @@map("holdings")
}

model Transaction {
  id        String          @id @default(cuid())
  userId    String          @map("user_id")
  assetId   String          @map("asset_id")
  type      TransactionType
  quantity  Decimal         @db.Decimal(18, 6)
  price     Decimal         @db.Decimal(18, 6)
  total     Decimal         @db.Decimal(18, 2)
  createdAt DateTime        @default(now()) @map("created_at")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset     Asset           @relation(fields: [assetId], references: [id])

  @@map("transactions")
}

enum AssetType {
  STOCK
  FX
  CRYPTO
  ETF
}

enum TransactionType {
  BUY
  SELL
}
