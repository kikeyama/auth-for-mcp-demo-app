# Auth0 Configuration
# Create a Regular Web Application in Auth0 Dashboard
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_SECRET=generate-with-openssl-rand-hex-32

# Auth0 API audience (for microservice access tokens)
# Create an API in Auth0 Dashboard > Applications > APIs
# Set the identifier (e.g. https://api.wealthvision.local) here
AUTH0_AUDIENCE=https://api.wealthvision.local

# Application
APP_BASE_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/wealth_mgmt

# Microservices
TRANSACTIONS_API_URL=http://localhost:4001
